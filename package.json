{
  "name": "wappstore",
  "version": "1.0.0",
  "description": "Multi-tenant conversational commerce platform for WhatsApp",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts",
    "build": "npm run clean && tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/database/migrate.ts",
    "db:seed": "tsx src/database/seeds/index.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "whatsapp",
    "commerce",
    "ecommerce",
    "mpesa",
    "kenya",
    "ai",
    "genkit",
    "conversational"
  ],
  "author": "Amos Korir - amoskorir631@gmail.com",
  "license": "MIT",
  "packageManager": "pnpm@10.22.0",
  "dependencies": {
    "@genkit-ai/ai": "^1.28.0",
    "@genkit-ai/core": "^1.28.0",
    "@genkit-ai/flow": "^0.5.17",
    "@genkit-ai/googleai": "^1.28.0",
    "@genkit-ai/vertexai": "^1.28.0",
    "@neondatabase/serverless": "^1.0.2",
    "axios": "^1.13.3",
    "bullmq": "^5.67.1",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "genkit": "^1.28.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "postgres": "^3.4.8",
    "winston": "^3.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "zod-to-json-schema": "3.24.3"
    }
  }
}