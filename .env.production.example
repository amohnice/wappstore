# =============================================
# MANDATORY VERCEL DEPLOYMENT VARIABLES
# =============================================

# Server Setup
NODE_ENV=production
API_BASE_URL=https://your-app-name.vercel.app

# Database (Neon recommended for Vercel)
DATABASE_URL=postgresql://user:password@host.region.neon.tech/dbname?sslmode=require

# External APIs
GOOGLE_GENAI_API_KEY=your_gemini_api_key

# WhatsApp (From Meta Developers console)
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_ACCESS_TOKEN=your_token
WHATSAPP_VERIFY_TOKEN=random_string_you_choose

# M-Pesa (Daraja API)
MPESA_CONSUMER_KEY=your_key
MPESA_CONSUMER_SECRET=your_secret
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://your-app-name.vercel.app/webhooks/mpesa

# Redis (Upstash recommended for Vercel)
REDIS_URL=redis://default:password@host:port

# Security
JWT_SECRET=generate_something_long_and_random
ENCRYPTION_KEY=32_byte_hex_string
