# =============================================
# SERVER CONFIGURATION
# =============================================
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# =============================================
# DATABASE
# =============================================

# Local PostgreSQL
DATABASE_URL=postgresql://commerce_user:your_password@localhost:5432/wappstore

# Or use hosted database (Neon, Supabase, etc.)
# DATABASE_URL=postgresql://user:password@host.region.neon.tech/dbname?sslmode=require

# =============================================
# REDIS
# =============================================

# Local Redis
REDIS_URL=redis://localhost:6379

# Or use hosted Redis (Upstash, Redis Cloud, etc.)
# REDIS_URL=redis://default:password@host:port

# =============================================
# WHATSAPP (Meta Cloud API)
# =============================================

# WhatsApp API Base URL (v18.0 recommended)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# Get from Meta Developer Console > Your App > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here

# Create your own random string for webhook verification
WHATSAPP_VERIFY_TOKEN=your_random_verify_token_12345

# Get from Meta Developer Console > WhatsApp > API Setup > Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# =============================================
# M-PESA (Safaricom Daraja API)
# =============================================

# SANDBOX CREDENTIALS (For Testing)
MPESA_CONSUMER_KEY=your_sandbox_consumer_key
MPESA_CONSUMER_SECRET=your_sandbox_consumer_secret
MPESA_PASSKEY=your_sandbox_passkey
MPESA_SHORTCODE=174379

# PRODUCTION CREDENTIALS (After Go-Live Approval)
# MPESA_CONSUMER_KEY=your_production_consumer_key
# MPESA_CONSUMER_SECRET=your_production_consumer_secret
# MPESA_PASSKEY=your_production_passkey
# MPESA_SHORTCODE=your_paybill_number

# Callback URL (must be HTTPS in production)
MPESA_CALLBACK_URL=https://your-domain.com/webhooks/mpesa

# Security Credential (for B2C - get during onboarding)
MPESA_SECURITY_CREDENTIAL=your_security_credential

# =============================================
# GOOGLE AI (Gemini)
# =============================================

# Get from https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your_gemini_api_key_here

# =============================================
# eTIMS (Kenya Revenue Authority)
# =============================================

# Production URL
ETIMS_API_URL=https://etims.kra.go.ke/api/v1

# Your eTIMS credentials (get from KRA)
ETIMS_API_KEY=your_etims_api_key
ETIMS_TIN=your_business_tin
ETIMS_BHF_ID=your_branch_id

# =============================================
# SECURITY
# =============================================

# Generate strong random string (32+ characters)
# You can use: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random

# Encryption key for sensitive data (32 bytes)
# You can use: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_encryption_key_in_hex_format

# =============================================
# PLATFORM SETTINGS
# =============================================

# Platform fee (percentage of each transaction)
PLATFORM_FEE_PERCENTAGE=5

# VAT percentage (Kenya standard rate)
VAT_PERCENTAGE=16

# Delivery fee default (KES)
DEFAULT_DELIVERY_FEE=200

# Free delivery threshold (KES)
FREE_DELIVERY_THRESHOLD=5000

# =============================================
# FILE STORAGE (Optional - Cloudflare R2)
# =============================================

# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET_NAME=wappstore-media
# R2_PUBLIC_URL=https://media.your-domain.com

# =============================================
# MONITORING & ERROR TRACKING (Optional)
# =============================================

# Sentry DSN for error tracking
# SENTRY_DSN=your_sentry_dsn_here

# PostHog for analytics
# POSTHOG_API_KEY=your_posthog_key
# POSTHOG_HOST=https://app.posthog.com

# =============================================
# EMAIL (Optional - for notifications)
# =============================================

# SMTP settings
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@wappstore.co.ke

# Or use SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key

# =============================================
# RATE LIMITING
# =============================================

# Max requests per 15 minutes per IP
RATE_LIMIT_MAX=100

# Max requests per minute for webhooks
WEBHOOK_RATE_LIMIT=60

# =============================================
# DEVELOPMENT ONLY
# =============================================

# Enable debug mode (verbose logging)
DEBUG=false

# Skip webhook signature verification (NEVER in production!)
SKIP_WEBHOOK_VERIFICATION=false

# Mock M-Pesa responses (for local testing without Daraja)
MOCK_MPESA=false
